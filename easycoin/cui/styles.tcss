/* Tailwind-style classes */
/* Padding and Margins */
.p-0 { padding: 0; }
.p-1 { padding: 1; }
.px-1 { padding: 0 1; }
.py-1 { padding: 1 0; }
.m-0 { margin: 0; }
.m-1 { margin: 1; }
.mx-1 { margin: 0 1; }
.my-1 { margin: 1 0; }
.mt-1 { margin: 1 0 0 0; }
.mb-1 { margin: 0 0 1 0; }
.border-solid-primary { border: solid $primary; }

/* Height */
.h-1 { height: 1; }
.h-2 { height: 2; }
.h-3 { height: 3; }
.h-4 { height: 4; }
.h-5 { height: 5; }
.h-6 { height: 6; }
.h-7 { height: 7; }
.h-8 { height: 8; }
.h-9 { height: 9; }
